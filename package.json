{
  "name": "x-bookmarks-sync",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build:plugin": "tsc --noEmit -p obsidian-plugin/tsconfig.json && esbuild obsidian-plugin/main.ts --bundle --format=cjs --target=es2018 --outfile=obsidian-plugin/main.js --external:obsidian --external:electron && node build.cjs",
    "build": "npm run build:plugin && vite build",
    "deploy:local": "npm run build:plugin && cp main.js manifest.json styles.css \"/Users/fei.hu/Dropbox/Obsidian Notes/.obsidian/plugins/x-bookmarks-sync/\"",
    "preview": "vite preview",
    "clean": "rm -rf dist-plugin",
    "lint": "tsc --noEmit && tsc --noEmit -p obsidian-plugin/tsconfig.json",
    "typecheck": "tsc --noEmit && tsc --noEmit -p obsidian-plugin/tsconfig.json"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "defuddle": "^0.13.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "prismjs": "^1.30.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/file-saver": "^2.0.7",
    "@types/jszip": "^3.4.0",
    "@types/node": "^22.14.0",
    "@types/prismjs": "^1.26.6",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.27.4",
    "obsidian": "^1.12.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
